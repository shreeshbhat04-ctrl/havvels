# NodeC_h2 — ESP32-H2: Zigbee End Device + BLE Peripheral (NimBLE)

# Enable Bluetooth
CONFIG_BT_ENABLED=y

# Use NimBLE
CONFIG_BT_NIMBLE_ENABLED=y
CONFIG_BT_NIMBLE_ROLE_CENTRAL=n
CONFIG_BT_NIMBLE_ROLE_PERIPHERAL=y
CONFIG_BT_NIMBLE_ROLE_OBSERVER=n
CONFIG_BT_NIMBLE_ROLE_BROADCASTER=y

# Zigbee End Device
CONFIG_ZB_ENABLED=y
CONFIG_ZB_ED_ROLE=y

# Custom partition table for Zigbee storage
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partition.csv"

# Software coexistence (BLE + 802.15.4)
CONFIG_ESP_COEX_SW_COEXIST_ENABLE=y
# Enable Bluetooth (NimBLE)
CONFIG_BT_ENABLED=y
CONFIG_BT_NIMBLE_ENABLED=y

# Enable 802.15.4 (Zigbee)
CONFIG_IEEE802154_ENABLED=y

# Enable coexistence — time-slices the single radio between Zigbee and BLE
CONFIG_ESP_COEX_SW_COEXIST_ENABLE=y

