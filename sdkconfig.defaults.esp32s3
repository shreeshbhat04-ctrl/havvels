# Haavvvels — ESP32-S3 specific defaults
# Enable software coexistence (Wi-Fi + BLE time-sharing)
CONFIG_ESP_COEX_SW_COEXIST_ENABLE=y
# BLE required for intercom mode (BLE scanner)
CONFIG_BT_ENABLED=y
CONFIG_BT_BLE_ENABLED=y
CONFIG_BT_BLUEDROID_ENABLED=y
# Wi-Fi + BLE binary exceeds 1MB — use large partition table
CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE=y

